# EduQuery AI — Environment Configuration
# Salin file ini sebagai .env dan sesuaikan isinya.

# ── Database ───────────────────────────────────────────
DB_IS_LOCAL=false
DB_HOST=localhost
DB_PORT=3306
DB_NAME=db_eduquery
DB_USER=root
DB_PASSWORD=p@ssw0rd!

# ── Ollama ─────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
# Model minimal 1B parameter untuk hasil terbaik.
# Hasil benchmark: gemma3:1b (tercepat + akurat), qwen3:1.7b (akurat tapi lambat)
# Rekomendasi CPU: gemma3:1b, GPU: llama3.2:3b atau qwen3:7b
OLLAMA_MODEL=gemma3:1b
OLLAMA_TIMEOUT=30

# ── App ────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000

# ── SQLite (hanya jika DB_IS_LOCAL=true) ───────────────
SQLITE_PATH=database/eduquery.db

# ── Academic ───────────────────────────────────────────
ACADEMIC_YEARS=2023/2024,2024/2025,2025/2026

# ── BP Batam Data Warehouse (Oracle) ──────────────────
BP_DB_USER=us_dwh
BP_DB_PASSWORD=DeWeHaRS20DuaFive
BP_DB_HOST=bpdb-scan.bpbatam.go.id:1521
BP_DB_SERVICE_NAME=begs
